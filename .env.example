# ─────────────────────────────────────────────────────────────────────────────
# Spoiler Alert — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required. Get from: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Required. Server-only — never expose to the client.
# Get from: Supabase project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Polar (Payments) ──────────────────────────────────────────────────────────
# Required for subscription features. Get from: polar.sh → Settings → API Keys
# Use a sandbox key (polar_oat_...) for development.
POLAR_ACCESS_TOKEN=your_polar_access_token_here

# Required for webhook signature verification. Get from: polar.sh → Webhooks → your webhook → Secret
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret_here

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "false" in development to bypass the subscription gate on the dashboard.
# Remove or set to "true" in production.
NEXT_PUBLIC_REQUIRE_SUBSCRIPTION=false

# ── Spoonacular (Recipe Suggestions) ─────────────────────────────────────────
# Optional. If missing or blank, recipe suggestions are silently disabled.
# Get from: spoonacular.com/food-api → sign up → Console Dashboard
# Free tier: 150 points/day. Each 6-recipe fetch costs 6 points (25 fetches/day max).
# Leave blank during heavy local testing to preserve your daily quota.
SPOONACULAR_API_KEY=your_spoonacular_api_key_here
